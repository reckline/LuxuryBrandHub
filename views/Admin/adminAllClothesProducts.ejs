    <div class="product-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 p-6 bg-gray-50/50 min-h-screen">
  <% products.forEach(product=> { %>
    
    <div class="product-card group relative bg-white rounded-[2.5rem] border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">
      
      <div class="absolute top-5 left-5 right-5 z-10 flex justify-between items-center">
        <span class="bg-black/80 backdrop-blur-md text-white text-[9px] font-black uppercase tracking-[0.2em] px-3 py-1.5 rounded-lg">
          <%= product.brand %>
        </span>
        <span class="<%= product.status === 'active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %> text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full shadow-sm">
          <%= product.status === "active" ? "● Show" : "○ Hide" %>
        </span>
      </div>

      <div class="relative aspect-[4/5] overflow-hidden bg-gray-100">
        <img src="<%= product.images[0] %>" class="product-img w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="<%= product.title %>" />
        
        <div class="absolute bottom-4 left-5">
          <span class="bg-white/90 backdrop-blur-sm text-gray-900 text-[10px] font-bold uppercase px-3 py-1 rounded-md shadow-sm">
            <%= product.gender %>
          </span>
        </div>
      </div>

      <div class="product-info p-6 flex flex-col flex-grow">
        <div class="mb-4">
          <h3 class="shoe-name text-xl font-black tracking-tighter text-gray-900 group-hover:text-blue-600 transition-colors truncate">
            <%= product.title %>
          </h3>
          <p class="text-gray-400 text-xs leading-relaxed line-clamp-2 mt-1 italic">
            <%= product.description %>
          </p>
        </div>

        <div class="flex items-center gap-3 mb-5">
          <% if(product.offerPercentage > 0) { %>
            <div class="flex flex-col">
              <span class="text-[10px] font-bold text-red-400 line-through">₹<%= product.price %></span>
              <span class="text-2xl font-black text-gray-900 leading-none">₹<%= product.offerPrice %></span>
            </div>
            <div class="bg-red-600 text-white text-[10px] font-black px-2 py-1 rounded-lg animate-pulse">
              <%= product.offerPercentage %>% OFF
            </div>
          <% } else { %>
            <span class="text-2xl font-black text-gray-900">₹<%= product.price %></span>
          <% } %>
        </div>

        <div class="mb-5">
          <p class="text-[9px] font-black text-gray-400 uppercase tracking-[0.1em] mb-2">Available Sizes</p>
          <div class="flex flex-wrap gap-1.5">
            <% product.sizes.forEach(size => { %>
              <span class="text-[10px] font-bold bg-gray-50 border border-gray-100 text-gray-600 px-2 py-1 rounded-md">
                <%= size %>
              </span>
            <% }) %>
          </div>
        </div>

        <div class="mt-auto">
          <div class="flex justify-between items-center mb-1.5">
            <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest">Inventory Stock</span>
            <span class="text-[10px] font-black <%= product.totalStock < 5 ? 'text-red-500 animate-bounce' : 'text-gray-900' %>">
              <%= product.totalStock %> Units
            </span>
          </div>
          <div class="w-full bg-gray-100 h-1.5 rounded-full overflow-hidden">
            <div class="bg-gray-900 h-full rounded-full transition-all duration-1000" style="width: <%= Math.min((product.totalStock / 50) * 100, 100) %>%"></div>
          </div>
        </div>

        <button class="mt-6 w-full bg-gray-900 text-white py-4 rounded-2xl text-[11px] font-black uppercase tracking-[0.2em] shadow-xl shadow-gray-200 group-hover:bg-blue-600 group-hover:shadow-blue-200 transition-all active:scale-95 flex items-center justify-center gap-2" 
                onclick='openEditModal(<%- JSON.stringify(product) %>)'>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
          Edit Product
        </button>
      </div>
    </div>

  <% }) %>
</div>
  </main>

  <!-- ============================== Add Clothes Modal ===================== -->


  <form action="/admin-howmanyclothesuploaded" method="POST" enctype="multipart/form-data">
    <div class="modal-overlay" id="addModal">
      <div class="modal-box">
        <div class="flex flex-col max-h-[90vh]">
  
  <div class="px-6 py-4 border-b border-gray-100 flex-shrink-0 bg-white">
    <h2 class="text-xl font-black tracking-tighter text-gray-900 uppercase">
      Add New <span class="text-blue-600">Clothes</span>
    </h2>
    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1">T-Shirts, Shirts, Jeans & More</p>
  </div>

  <div class="p-6 overflow-y-auto custom-scrollbar flex-grow space-y-5" style="max-height: 60vh;">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Clothes Name</label>
        <input type="text" name="title" placeholder="Clothes Name" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Price (₹)</label>
        <input type="number" name="price" placeholder="₹ 0.00" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
    </div>

    <div class="form-group">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Description</label>
      <textarea name="description" rows="3" placeholder="Fabric details, fit, and style guide..." 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-medium focus:ring-2 focus:ring-blue-500 outline-none resize-none transition-all" required></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Offer (%)</label>
        <input type="number" name="offerPercentage" value="0"
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block font-bold">Total Stock</label>
        <input type="number" name="totalStock" placeholder="Total Stock" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" required />
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 p-5 bg-gray-50 rounded-[2rem] border border-gray-100">
      <div class="flex flex-col text-center">
        <label class="text-[9px] font-black text-gray-400 uppercase mb-1">Gender</label>
        <select name="gender" class="bg-transparent border-none font-bold text-gray-900 text-xs focus:ring-0 outline-none cursor-pointer" required>
          <option value="male">Male</option>
          <option value="female">Female</option>
          <option value="unisex">Unisex</option>
        </select>
      </div>
      <div class="flex flex-col text-center border-l border-gray-200">
        <label class="text-[9px] font-black text-gray-400 uppercase mb-1">Brand</label>
        <select name="brand" class="bg-transparent border-none font-bold text-gray-900 text-xs focus:ring-0 outline-none cursor-pointer" required>
          <option>HRX</option>
          <option>BLACKBERRY</option>
          <option>NIKE</option>
          <option>PUMA</option>
          <option>H&M</option>
          <option>LEE</option>
        </select>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 block italic">Select Sizes ✔</label>
      <div class="flex flex-wrap gap-2 px-1">
        <% ['XS', 'S', 'M', 'L', 'XL', 'XXL', '3XL', '4XL'].forEach(size => { %>
          <label class="cursor-pointer group">
            <input type="checkbox" name="sizes" value="<%= size %>" class="peer hidden" />
            <span class="px-4 py-2 flex items-center justify-center rounded-xl bg-gray-50 text-[11px] font-black text-gray-400 border border-gray-100 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:border-blue-600 peer-checked:shadow-lg peer-checked:shadow-blue-100 transition-all uppercase">
              <%= size %>
            </span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-blue-600 uppercase ml-2 block font-bold">Product Images (Max 4)</label>
      <input type="file" name="images" accept="image/*" multiple 
        class="w-full text-xs text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer hover:file:bg-blue-600 transition-all" required />
      <p class="text-[9px] text-gray-400 italic ml-2">Max 4 images • Each max 2MB</p>
    </div>

    <input type="hidden" name="category" value="clothes" />

  </div>

  <div class="p-6 border-t border-gray-50 flex gap-4 bg-white flex-shrink-0">
    <button type="button" class="flex-1 py-4 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-all" onclick="closeModal('addModal')">
      Discard
