    <div class="product-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 p-4 md:p-6">
  <% products.forEach(product=> { %>
    <div class="product-card group relative bg-white rounded-[2rem] border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">
      
      <div class="absolute top-4 right-4 z-10">
        <span class="<%= product.status === 'active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %> text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full backdrop-blur-md">
          <%= product.status === "active" ? "● Visible" : "○ Hidden" %>
        </span>
      </div>

      <div class="relative aspect-square overflow-hidden bg-gray-50">
        <img src="<%= product.images[0] %>" class="product-img w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="<%= product.title %>" />
        
        <div class="absolute bottom-4 left-4">
          <span class="bg-black/80 text-white text-[9px] font-bold uppercase tracking-widest px-3 py-1 rounded-lg backdrop-blur-sm">
            <%= product.gender %>
          </span>
        </div>
      </div>

      <div class="product-info p-6 flex flex-col flex-grow">
        <div class="mb-2">
          <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest mb-1"><%= product.brand || 'Premium' %></p>
          <h3 class="shoe-name text-xl font-black tracking-tighter text-gray-900 truncate">
            <%= product.title %>
          </h3>
        </div>

        <p class="text-gray-400 text-xs leading-relaxed line-clamp-2 mb-4">
          <%= product.description %>
        </p>

        <div class="flex items-end gap-2 mb-4">
          <% if (product.offerPercentage > 0) { %>
            <div class="flex flex-col">
              <span class="text-[10px] font-bold text-red-500 line-through opacity-60">₹<%= product.price %></span>
              <span class="text-2xl font-black text-gray-900 leading-none">₹<%= product.offerPrice %></span>
            </div>
            <span class="bg-red-50 text-red-600 text-[10px] font-black px-2 py-1 rounded-md mb-0.5">
              -<%= product.offerPercentage %>%
            </span>
          <% } else { %>
            <span class="text-2xl font-black text-gray-900">₹<%= product.price %></span>
          <% } %>
        </div>

        <div class="flex items-center gap-2 mb-6">
          <div class="flex-grow bg-gray-100 h-1.5 rounded-full overflow-hidden">
            <div class="bg-blue-600 h-full rounded-full" style="width: <%= Math.min(product.totalStock, 100) %>%"></div>
          </div>
          <span class="text-[10px] font-black text-gray-500 uppercase tracking-tighter shrink-0">
            Stock: <%= product.totalStock %>
          </span>
        </div>

        <button class="w-full bg-gray-900 text-white py-4 rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-lg shadow-gray-200 group-hover:bg-blue-600 group-hover:shadow-blue-200 transition-all active:scale-95" 
                onclick='openEditModal(<%- JSON.stringify(product) %>)'>
          Edit Product
        </button>
      </div>
    </div>
  <% }) %>
</div>

<style>
  /* चिकनी एनीमेशन के लिए */
  .product-card {
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  /* Description को 2 लाइन के बाद ... करने के लिए */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

  </main>

  <!-- ============================== Add Glasses Modal ===================== -->

  <form action="/admin-howmanyglassesuploaded" method="POST" enctype="multipart/form-data">
    <div class="modal-overlay" id="addModal">
      <div class="modal-box">
     <div class="flex flex-col max-h-[90vh]">
  
  <div class="px-6 py-4 border-b border-gray-100 flex-shrink-0 bg-white">
    <h2 class="text-xl font-black tracking-tighter text-gray-900 uppercase">
      Add New <span class="text-blue-600">Glasses</span>
    </h2>
    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1">Spectacles, Sunglasses & Frames</p>
  </div>

  <div class="p-6 overflow-y-auto custom-scrollbar flex-grow space-y-5" style="max-height: 60vh;">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Glasses Name</label>
        <input type="text" name="title" placeholder="Glasses Name" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Price (₹)</label>
        <input type="number" name="price" placeholder="₹ 0.00" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
    </div>

    <div class="form-group">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Product Description</label>
      <textarea name="description" rows="3" placeholder="Describe the frame material, lens type, style, etc." 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-medium focus:ring-2 focus:ring-blue-500 outline-none resize-none transition-all" required></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Offer (%)</label>
        <input type="number" name="offerPercentage" value="0"
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Total Stock</label>
        <input type="number" name="totalStock" placeholder="Total Stock" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" required />
      </div>
    </div>

    <div class="p-5 bg-gray-50 rounded-[2rem] border border-gray-100">
      <div class="flex flex-col text-center">
        <label class="text-[9px] font-black text-gray-400 uppercase mb-2 tracking-widest">Target Gender</label>
        <select name="gender" class="bg-transparent border-none font-bold text-gray-900 text-xs text-center focus:ring-0 outline-none cursor-pointer" required>
          <option value="male">Male</option>
          <option value="female">Female</option>
          <option value="unisex">Unisex</option>
        </select>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-blue-600 uppercase ml-2 block font-bold tracking-widest">Product Images (3–4)</label>
      <div class="relative w-full">
        <input type="file" name="images" accept="image/*" multiple 
          class="w-full text-xs text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer hover:file:bg-blue-600 transition-all" required />
      </div>
      <p class="text-[9px] text-gray-400 italic font-medium ml-2">Max 4 images • High resolution recommended</p>
    </div>

    <input type="hidden" name="category" value="glasses" />

  </div>

  <div class="p-6 border-t border-gray-50 flex gap-4 bg-white flex-shrink-0">
    <button type="button" class="flex-1 py-4 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-all" onclick="closeModal('addModal')">
      Discard
    </button>
    <button type="submit" class="flex-[2] py-4 bg-gray-900 text-white rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-xl shadow-gray-200 hover:bg-blue-600 hover:shadow-blue-100 transition-all active:scale-95">
      Add Product
    </button>
  </div>
</div>
      </div>
    </div>
  </form>
  <!-- ============================== Edit Modal ===================== -->

  <form action="/admin-editglassesproducts" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="productId" id="editProductId" />

    <div class="modal-overlay" id="editModal" style="overflow-y: scroll;">
   <div class="modal-box relative bg-white w-full max-w-2xl rounded-[2.5rem] shadow-2xl flex flex-col max-h-[90vh] transform scale-95 transition-all duration-300 border border-gray-100 overflow-hidden">
    
    <div class="p-6 border-b border-gray-50 flex-shrink-0 bg-white">
      <h2 class="text-2xl font-black tracking-tighter text-gray-900 uppercase">
        Update <span class="text-blue-600">Product</span>
      </h2>
      <p class="text-[10px] text-gray-400 font-bold tracking-widest uppercase mt-1">Don't forget to save your changes</p>
    </div>

    <div class="p-6 overflow-y-auto custom-scrollbar flex-grow bg-white">
      <form id="editForm" method="POST" enctype="multipart/form-data" class="space-y-5">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="flex flex-col">
            <label class="text-[10px] font-black uppercase text-gray-400 mb-1 ml-1">Product Name</label>
            <input type="text" name="title" id="editName" placeholder="Glasses Name" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-blue-500 transition-all outline-none" required />
          </div>
          <div class="flex flex-col">
            <label class="text-[10px] font-black uppercase text-gray-400 mb-1 ml-1">Price (₹)</label>
            <input type="number" name="price" id="editPrice" placeholder="Price (₹)" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-blue-500 transition-all outline-none" required />
          </div>
        </div>

        <div class="flex flex-col">
          <label class="text-[10px] font-black uppercase text-gray-400 mb-1 ml-1">Description</label>
          <textarea name="description" id="editDescription" rows="3" placeholder="Description" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-blue-500 outline-none resize-none" required></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="flex flex-col">
            <label class="text-[10px] font-black uppercase text-gray-400 mb-1 ml-1">Offer (%)</label>
            <input type="number" name="offerPercentage" id="editOffer" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-blue-500 outline-none" />
          </div>
          <div class="flex flex-col">
            <label class="text-[10px] font-black uppercase text-gray-400 mb-1 ml-1">Total Stock</label>
            <input type="number" name="totalStock" id="editStock" placeholder="Total Stock" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-blue-500 outline-none" />
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4 p-4 bg-gray-50 rounded-2xl border border-gray-100">
          <div class="flex flex-col">
            <label class="text-[9px] font-black text-gray-400 uppercase">Gender</label>
            <select name="gender" id="editGender" class="bg-transparent border-none font-bold text-gray-800 text-sm py-1 cursor-pointer outline-none">
              <option value="male">Male</option>
              <option value="female">Female</option>
              <option value="unisex">Unisex</option>
            </select>
          </div>
          <div class="flex flex-col border-l border-gray-200 pl-4">
            <label class="text-[9px] font-black text-gray-400 uppercase">Status</label>
            <select name="status" id="editStatus" class="bg-transparent border-none font-bold text-gray-800 text-sm py-1 cursor-pointer outline-none">
              <option value="active">Show</option>
              <option value="inactive">Hide</option>
            </select>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-[10px] font-black uppercase text-gray-400 ml-1">Current Images</label>
          <div id="editImagePreview" class="flex flex-wrap gap-2 p-2 bg-gray-50 rounded-xl border border-gray-100 min-h-[50px]">
            </div>
        </div>

        <div class="space-y-2">
          <label class="text-[10px] font-black uppercase text-gray-400 ml-1 font-bold">Upload New Images</label>
          <input type="file" name="images" accept="image/*" multiple class="w-full text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer" />
          <p class="text-[9px] text-gray-400 italic font-medium ml-1">Leave empty to keep old images</p>
        </div>

        <div class="flex gap-4 pt-4 border-t border-gray-50">
          <button type="button" class="flex-1 py-3 text-xs font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-colors" onclick="closeModal('editModal')">
            Cancel
          </button>
          <button type="submit" class="flex-[2] py-3 bg-blue-600 text-white rounded-xl text-xs font-black uppercase tracking-widest shadow-lg shadow-blue-100 hover:bg-gray-900 transition-all active:scale-95">
            Update Changes
          </button>
        </div>
      </form>
    </div>
  </div>
    </div>
  </form>
  <script src="/js/glassesProduct.js"></script>
</body>

</html>