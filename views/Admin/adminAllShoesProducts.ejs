    <i class="fa-solid fa-bars" style="font-size: 1.5rem; cursor: pointer" onclick="toggleSidebar()"></i>
  </header>

  <%- include('../partials/adminNavBar') %>

    <main class="main-content">
      <header style="
          display: flex;
          justify-content: space-between;
          align-items: center;
          flex-wrap: wrap;
          gap: 10px;
        ">

        <h1 class="relative inline-block text-1xl md:text-2xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-gray-900 via-blue-800 to-gray-900">
    Shoe Products
  </h1>

        <div class="select-wrapper">
          <select id="Display" onchange="filterShoes(this.value)">
            <option value="all" <%=selectedFilter==='all' ? 'selected' : '' %>>
              All
            </option>
            <option value="show" <%=selectedFilter==='show' ? 'selected' : '' %>>
              Show
            </option>
            <option value="hide" <%=selectedFilter==='hide' ? 'selected' : '' %>>
              Hide
            </option>
          </select>
        </div>




        <button class="btn-add" onclick="openModal('addModal')">
          + Add New Shoes
        </button>
      </header>

