<div class="product-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 p-6">
  <% products.forEach(product=> { %>
    <div class="product-card group relative card-gradient rounded-[2rem] border border-gray-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col">
      
      <div class="absolute top-4 left-4 right-4 z-10 flex justify-between items-center">
        <span class="bg-white/90 backdrop-blur-md text-gray-900 text-[9px] font-extrabold uppercase tracking-tighter px-3 py-1.5 rounded-full shadow-sm border border-gray-100">
          <%= product.brand %>
        </span>
        <span class="<%= product.status === 'active' ? 'bg-green-500' : 'bg-red-500' %> w-2.5 h-2.5 rounded-full shadow-[0_0_8px_rgba(0,0,0,0.1)] border-2 border-white" title="<%= product.status %>"></span>
      </div>

      <div class="relative aspect-square overflow-hidden bg-gray-50">
        <img src="<%= product.images[0] %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
        <div class="absolute bottom-3 right-3">
           <span class="bg-gray-900/10 backdrop-blur-sm text-gray-900 text-[10px] font-bold px-2 py-1 rounded-lg border border-gray-900/5">
            <%= product.gender %>
          </span>
        </div>
      </div>

      <div class="p-5 flex flex-col flex-grow">
        <h3 class="text-lg font-bold text-gray-900 leading-tight mb-1 truncate">
          <%= product.title %>
        </h3>
        <p class="text-gray-500 text-[11px] line-clamp-2 mb-4 leading-relaxed">
          <%= product.description %>
        </p>

        <div class="flex items-baseline gap-2 mb-4">
          <% if(product.offerPercentage > 0) { %>
            <span class="text-xl font-extrabold text-gray-900">₹<%= product.offerPrice %></span>
            <span class="text-xs font-bold text-red-500 line-through opacity-50">₹<%= product.price %></span>
            <span class="ml-auto text-[10px] font-black text-red-600 bg-red-50 px-2 py-0.5 rounded-md"><%= product.offerPercentage %>% OFF</span>
          <% } else { %>
            <span class="text-xl font-extrabold text-gray-900">₹<%= product.price %></span>
          <% } %>
        </div>

        <div class="mb-4">
          <div class="flex flex-wrap gap-1">
            <% product.sizes.forEach(size => { %>
              <span class="text-[9px] font-bold bg-white border border-gray-200 text-gray-500 w-7 h-7 flex items-center justify-center rounded-lg shadow-sm">
                <%= size %>
              </span>
            <% }) %>
          </div>
        </div>

        <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between">
          <div class="flex flex-col">
            <span class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Stock</span>
            <span class="text-xs font-extrabold <%= product.totalStock < 10 ? 'text-red-600' : 'text-gray-900' %>">
              <%= product.totalStock %> Units
            </span>
          </div>
          
          <button class="bg-gray-900 text-white p-3 rounded-2xl hover:bg-blue-600 transition-colors shadow-lg shadow-gray-200 active:scale-90" 
                  onclick='openEditModal(<%- JSON.stringify(product) %>)'>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
          </button>
        </div>
      </div>
    </div>
  <% }) %>
</div>
  </main>

  <!-- ============================== Add Sliders Modal ===================== -->

  <form action="/admin-howmanyslidersuploaded" method="POST" enctype="multipart/form-data">
    <div class="modal-overlay" id="addModal">
      <div class="modal-box">
       <div class="flex flex-col max-h-[90vh]">
  
  <div class="px-6 py-4 border-b border-gray-100 flex-shrink-0 bg-white">
    <h2 class="text-xl font-black tracking-tighter text-gray-900 uppercase text-center md:text-left">
      Add New <span class="text-blue-600">Sliders</span>
    </h2>
    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1 text-center md:text-left">Flip-flops & Comfort Wear</p>
  </div>

  <div class="p-6 overflow-y-auto custom-scrollbar flex-grow space-y-5" style="max-height: 60vh;">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Sliders Name</label>
        <input type="text" name="title" placeholder="Sliders Name" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Price (₹)</label>
        <input type="number" name="price" placeholder="₹ 0.00" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
    </div>

    <div class="form-group">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Description</label>
      <textarea name="description" rows="3" placeholder="Enter slider material, comfort level, grip details, etc." 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-medium focus:ring-2 focus:ring-blue-500 outline-none resize-none transition-all" required></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Offer (%)</label>
        <input type="number" name="offerPercentage" value="0"
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block font-bold">Total Stock</label>
        <input type="number" name="totalStock" placeholder="Total Stock" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" required />
      </div>
    </div>

    <div class="p-5 bg-gray-50 rounded-[2rem] border border-gray-100">
      <div class="flex flex-col text-center">
        <label class="text-[9px] font-black text-gray-400 uppercase mb-2 tracking-widest">Gender</label>
        <select name="gender" class="bg-transparent border-none font-bold text-gray-900 text-xs text-center focus:ring-0 outline-none cursor-pointer" required>
          <option value="male">Male</option>
          <option value="female">Female</option>
          <option value="unisex">Unisex</option>
        </select>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 block italic">Select Sizes ✔</label>
      <div class="flex flex-wrap gap-2 px-1">
        <% ['6', '6.5', '7', '7.5', '8', '8.5', '9', '9.5', '10', '10.5', '11'].forEach(size => { %>
          <label class="cursor-pointer group">
            <input type="checkbox" name="sizes" value="<%= size %>" class="peer hidden" />
            <span class="w-12 h-10 flex items-center justify-center rounded-xl bg-gray-50 text-[11px] font-black text-gray-400 border border-gray-100 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:border-blue-600 peer-checked:shadow-lg peer-checked:shadow-blue-100 transition-all uppercase">
              <%= size %>
            </span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-blue-600 uppercase ml-2 block font-bold">Product Images (Max 4)</label>
      <input type="file" name="images" accept="image/*" multiple 
        class="w-full text-xs text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer hover:file:bg-blue-600 transition-all" required />
      <p class="text-[9px] text-gray-400 italic ml-2">Upload front, side, and sole views</p>
    </div>

    <input type="hidden" name="category" value="sliders" />

  </div>

  <div class="p-6 border-t border-gray-50 flex gap-4 bg-white flex-shrink-0">
    <button type="button" class="flex-1 py-4 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-all" onclick="closeModal('addModal')">
      Discard
    </button>
    <button type="submit" class="flex-[2] py-4 bg-gray-900 text-white rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-xl shadow-gray-200 hover:bg-blue-600 hover:shadow-blue-200 transition-all active:scale-95">
      Add Product
    </button>
  </div>
</div>
      </div>
    </div>
  </form>
  <!-- ============================== Edit Sliders Modal ===================== -->

  <form action="/admin-editsliderslproducts" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="productId" id="editProductId" />

    <div class="modal-overlay" id="editModal">
      <div class="modal-box">
        <div class="flex flex-col max-h-[90vh]">
  
  <div class="px-6 py-4 border-b border-gray-100 flex-shrink-0 bg-white">
    <h2 class="text-xl font-black tracking-tighter text-gray-900 uppercase">
      Edit <span class="text-blue-600">Slider Product</span>
    </h2>
  </div>

  <div class="p-6 overflow-y-auto custom-scrollbar flex-grow space-y-5" style="max-height: 60vh;">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Sliders Name</label>
        <input type="text" name="title" id="editName" placeholder="Sliders Name" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Price (₹)</label>
        <input type="number" name="price" id="editPrice" placeholder="Price (₹)" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
    </div>

    <div class="form-group">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Product Description</label>
      <textarea name="description" id="editDescription" rows="3" placeholder="Description" 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-medium focus:ring-2 focus:ring-blue-500 outline-none resize-none transition-all" required></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Offer (%)</label>
        <input type="number" name="offerPercentage" id="editOffer" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block">Total Stock</label>
        <input type="number" name="totalStock" id="editStock" placeholder="Total Stock" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>
    </div>

    <div class="flex items-center justify-around p-4 bg-gray-50 rounded-[1.5rem] border border-gray-100">
      <div class="text-center">
        <label class="text-[9px] font-black text-gray-400 uppercase block mb-1">Gender</label>
        <select name="gender" id="editGender" class="bg-transparent border-none font-bold text-gray-800 text-xs focus:ring-0 outline-none cursor-pointer">
          <option value="male">Male</option>
          <option value="female">Female</option>
          <option value="unisex">Unisex</option>
        </select>
      </div>
      <div class="w-[1px] h-8 bg-gray-200"></div>
      <div class="text-center">
        <label class="text-[9px] font-black text-gray-400 uppercase block mb-1">Status</label>
        <select name="status" id="editStatus" class="bg-transparent border-none font-bold text-gray-800 text-xs focus:ring-0 outline-none cursor-pointer">
          <option value="active">Show</option>
          <option value="inactive">Hide</option>
        </select>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 block">Select Size ✔</label>
      <div class="flex flex-wrap gap-2 px-1">
        <% ['6', '6.5', '7', '7.5', '8', '8.5', '9', '9.5', '10', '10.5', '11', '11.5', '12'].forEach(size => { %>
          <label class="cursor-pointer group">
            <input type="checkbox" name="sizes" value="<%= size %>" class="peer hidden" />
            <span class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-50 text-[11px] font-black text-gray-400 border border-gray-100 peer-checked:bg-blue-600 peer-checked:text-white peer-checked:border-blue-600 peer-checked:shadow-lg peer-checked:shadow-blue-100 transition-all uppercase">
              <%= size %>
            </span>
          </label>
        <% }) %>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 block">Current Images</label>
      <div id="editImagePreview" class="flex flex-wrap gap-2 p-3 bg-white rounded-2xl border-2 border-dashed border-gray-100 min-h-[80px] items-center">
        </div>
    </div>

    <div class="space-y-2">
      <label class="text-[10px] font-black text-blue-600 uppercase ml-2 block font-bold">Upload New Images</label>
      <input type="file" name="images" accept="image/*" multiple 
        class="w-full text-xs text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer hover:file:bg-blue-600 transition-all" />
      <p class="text-[9px] text-gray-400 italic ml-2 tracking-tight">Leave empty to keep current images</p>
    </div>

  </div>

  <div class="p-6 border-t border-gray-50 flex gap-4 bg-white flex-shrink-0">
    <button type="button" class="flex-1 py-4 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-colors" onclick="closeModal('editModal')">
      Cancel
    </button>
    <button type="submit" class="flex-[2] py-4 bg-gray-900 text-white rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-xl shadow-gray-200 hover:bg-blue-600 hover:shadow-blue-100 transition-all active:scale-95">
      Update Changes
    </button>
  </div>
</div>
      </div>
    </div>
  </form>

  <script src="/js/slidersProduct.js"></script>
</body>

</html>