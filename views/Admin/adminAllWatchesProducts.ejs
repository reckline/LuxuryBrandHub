<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Products | <%-admin.username%></title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/admin-product.css">
  <script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">

<style>
  /* पूरे पेज का बैकग्राउंड और फॉन्ट सेटअप */
  body {
    font-family: 'Inter', sans-serif;
    background-color: #f8fafc; /* लाइट ग्रे बैकग्राउंड */
    color: #1e293b;
  }

  /* सुंदर स्क्रॉलबार (Modals के लिए) */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #cbd5e1;
  }

  /* Modal Animations: जब Modal खुलेगा तो हल्का सा ज़ूम और फेड होगा */
  #editModal, #addModal {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .modal-box {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Description को 2 लाइन तक सीमित रखने के लिए */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Status Badges के लिए ग्लो इफेक्ट */
  .status-glow-active {
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.2);
  }
  
  .status-glow-hidden {
    box-shadow: 0 0 10px rgba(239, 68, 68, 0.2);
  }
</style>

</head>

<body>
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <header class="mobile-header">
    <span style="font-weight: 800; font-size: 1.2rem"><%-admin.username%></span>
    <i class="fa-solid fa-bars" style="font-size: 1.5rem; cursor: pointer" onclick="toggleSidebar()"></i>
  </header>

<%- include('../partials/adminNavBar') %>

  <main class="main-content">
    <header style="
          display: flex;
          justify-content: space-between;
          align-items: center;
          flex-wrap: wrap;
          gap: 10px;
        ">

      <h1>Products</h1>

      <div class="select-wrapper">
        <select id="Display" onchange="filterWatches(this.value)">
          <option value="all" <%=selectedFilter==='all' ? 'selected' : '' %>>
            All
          </option>
          <option value="show" <%=selectedFilter==='show' ? 'selected' : '' %>>
            Show
          </option>
          <option value="hide" <%=selectedFilter==='hide' ? 'selected' : '' %>>
            Hide
          </option>
        </select>
      </div>



      <button class="btn-add" onclick="openModal('addModal')">
        + Add Product
      </button>
    </header>

    <!-- <div class="product-grid">
      <% products.forEach(product=> { %>
        <div class="product-card">
          <img src="<%= product.images[0] %>" class="product-img" />

          <div class="product-info">
            <h3 class="shoe-name">
              <%= product.title %>
            </h3>
            <p style="color:gray; font-size:13px;">
              <%= product.description %>
            </p>
            <p class="shoe-price">₹<%= product.price %>
            </p>

            <% if (product.offerPercentage> 0) { %>
              <p class="shoe-offer" style="color:red;">
                Offer <%= product.offerPercentage %>%
              </p>
              <p class="shoe-offer-price" style="color:green;">
                Offer Price ₹<%= product.offerPrice %>
              </p>
              <% } %>

                <p class="shoe-stock" style="color:red;">
                  Total Stock <%= product.totalStock %>
                </p>

                <p style="color:blue;">
                  <%= product.gender %>
                </p>

                <p style="color:goldenrod;">
                  <%= product.status==="active" ? "Show" : "Hide" %>
                </p>

                <button class="btn-edit" onclick='openEditModal(<%- JSON.stringify(product) %>)'>
                  Edit Product
                </button>
          </div>
        </div>
        <% }) %>
    </div> -->

    <div class="product-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 p-6 bg-gray-50/50">
  <% products.forEach(product=> { %>
    <div class="product-card group relative bg-white rounded-[2.5rem] border border-gray-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden flex flex-col">
      
      <div class="absolute top-5 right-5 z-10">
        <span class="<%= product.status === 'active' ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %> text-[10px] font-black uppercase tracking-widest px-4 py-2 rounded-full backdrop-blur-md shadow-sm">
          <%= product.status === "active" ? "● Show" : "○ Hide" %>
        </span>
      </div>

      <div class="relative aspect-square overflow-hidden bg-gray-100">
        <img src="<%= product.images[0] %>" class="product-img w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
        
        <div class="absolute bottom-4 left-4">
          <span class="bg-black/80 text-white text-[9px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-xl backdrop-blur-sm">
            <%= product.gender %>
          </span>
        </div>
      </div>

      <div class="product-info p-6 flex flex-col flex-grow">
        <div class="mb-3">
          <h3 class="shoe-name text-xl font-black tracking-tighter text-gray-900 truncate">
            <%= product.title %>
          </h3>
          <p class="text-gray-400 text-[11px] leading-relaxed line-clamp-2 mt-1">
            <%= product.description %>
          </p>
        </div>

        <div class="flex items-center gap-2 mb-4">
          <% if (product.offerPercentage > 0) { %>
            <div class="flex flex-col">
              <span class="text-[10px] font-bold text-red-400 line-through">₹<%= product.price %></span>
              <span class="text-2xl font-black text-gray-900 leading-none">₹<%= product.offerPrice %></span>
            </div>
            <span class="bg-red-600 text-white text-[10px] font-black px-2 py-1 rounded-lg">
              -<%= product.offerPercentage %>%
            </span>
          <% } else { %>
            <span class="text-2xl font-black text-gray-900">₹<%= product.price %></span>
          <% } %>
        </div>

        <div class="mt-auto">
          <div class="flex justify-between items-center mb-1.5">
            <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Availability</span>
            <span class="text-[10px] font-bold <%= product.totalStock < 5 ? 'text-red-500' : 'text-gray-600' %> uppercase">
              Stock <%= product.totalStock %>
            </span>
          </div>
          <div class="w-full bg-gray-100 h-2 rounded-full overflow-hidden">
            <div class="bg-gray-900 h-full rounded-full transition-all duration-1000" style="width: <%= Math.min((product.totalStock / 20) * 100, 100) %>%"></div>
          </div>
        </div>

        <button class="mt-6 w-full bg-gray-900 text-white py-4 rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-xl shadow-gray-200 group-hover:bg-blue-600 group-hover:shadow-blue-200 transition-all active:scale-95" 
                onclick='openEditModal(<%- JSON.stringify(product) %>)'>
          Edit Details
        </button>
      </div>
    </div>
  <% }) %>
</div>
  </main>

  <!-- ============================== Add Watches Modal ===================== -->

  <form action="/admin-howmanywatchesuploaded" method="POST" enctype="multipart/form-data">
    <div class="modal-overlay" id="addModal">
      <div class="modal-box">
       <div class="flex flex-col max-h-[90vh]">
  
  <div class="px-6 py-4 border-b border-gray-100 flex-shrink-0 bg-white">
    <h2 class="text-xl font-black tracking-tighter text-gray-900 uppercase">
      Add New <span class="text-blue-600">Watch</span>
    </h2>
    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mt-1">Luxury, Sport & Casual Timepieces</p>
  </div>

  <div class="p-6 overflow-y-auto custom-scrollbar flex-grow space-y-5" style="max-height: 60vh;">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Watch Name</label>
        <input type="text" name="title" placeholder="Watches Name" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Price (₹)</label>
        <input type="number" name="price" placeholder="₹ 0.00" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
      </div>
    </div>

    <div class="form-group">
      <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Product Description</label>
      <textarea name="description" rows="3" placeholder="Describe strap material, dial color, movement type, etc." 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-medium focus:ring-2 focus:ring-blue-500 outline-none resize-none transition-all" required></textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Offer (%)</label>
        <input type="number" name="offerPercentage" value="0"
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" />
      </div>
      <div class="form-group">
        <label class="text-[10px] font-black text-gray-400 uppercase ml-2 mb-1 block tracking-widest">Total Stock</label>
        <input type="number" name="totalStock" placeholder="Total Stock" 
          class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-bold focus:ring-2 focus:ring-blue-500 outline-none" required />
      </div>
    </div>

    <div class="p-5 bg-gray-50 rounded-[2rem] border border-gray-100">
      <div class="flex flex-col text-center">
        <label class="text-[9px] font-black text-gray-400 uppercase mb-2 tracking-widest">Target Gender</label>
        <select name="gender" class="bg-transparent border-none font-bold text-gray-900 text-xs text-center focus:ring-0 outline-none cursor-pointer" required>
          <option value="male">Male</option>
          <option value="female">Female</option>
          <option value="unisex">Unisex</option>
        </select>
      </div>
    </div>

    <div class="space-y-3">
      <label class="text-[10px] font-black text-blue-600 uppercase ml-2 block font-bold tracking-widest">Watch Images (3–4)</label>
      <div class="relative w-full">
        <input type="file" name="images" accept="image/*" multiple 
          class="w-full text-xs text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer hover:file:bg-blue-600 transition-all" required />
      </div>
      <p class="text-[9px] text-gray-400 italic font-medium ml-2">Max 4 images • Clear dial shots recommended</p>
    </div>

    <input type="hidden" name="category" value="watch" />

  </div>

  <div class="p-6 border-t border-gray-50 flex gap-4 bg-white flex-shrink-0">
    <button type="button" class="flex-1 py-4 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-all" onclick="closeModal('addModal')">
      Discard
    </button>
    <button type="submit" class="flex-[2] py-4 bg-gray-900 text-white rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-xl shadow-gray-200 hover:bg-blue-600 hover:shadow-blue-100 transition-all active:scale-95">
      Add Product
    </button>
  </div>
</div>
      </div>
    </div>
  </form>

  <!-- ============================== Edit Modal ===================== -->

  <form action="/admin-editwatchesproducts" method="POST" enctype="multipart/form-data">
    <input type="hidden" name="productId" id="editProductId" />

    <div class="modal-overlay" id="editModal" style="overflow-y: scroll;">
      <div class="modal-box" style="overflow-y: scroll; position: relative; top: 5rem;">
        <!-- <h2>Edit Product</h2> -->

       <div class="space-y-5">
  <div class="form-group">
    <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-1 block">Watch Name</label>
    <input type="text" name="title" id="editName" placeholder="Watch Name" 
      class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-semibold focus:ring-2 focus:ring-blue-500 transition-all outline-none" required />
  </div>

  <div class="form-group">
    <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-1 block">Price (₹)</label>
    <input type="number" name="price" id="editPrice" placeholder="Price (₹)" 
      class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-semibold focus:ring-2 focus:ring-blue-500 transition-all outline-none" required />
  </div>

  <div class="form-group">
    <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-1 block">Product Description</label>
    <textarea name="description" id="editDescription" rows="3" placeholder="Description" 
      class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-semibold focus:ring-2 focus:ring-blue-500 transition-all outline-none resize-none" required></textarea>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div class="form-group">
      <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-1 block">Offer (%)</label>
      <input type="number" name="offerPercentage" id="editOffer" 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-semibold focus:ring-2 focus:ring-blue-500 outline-none" />
    </div>
    <div class="form-group">
      <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-1 block">Stock Count</label>
      <input type="number" name="totalStock" id="editStock" placeholder="Total Stock" 
        class="w-full bg-gray-50 border-none rounded-2xl px-5 py-4 text-sm font-semibold focus:ring-2 focus:ring-blue-500 outline-none" />
    </div>
  </div>

  <div class="flex items-center justify-between gap-4 p-4 bg-gray-50 rounded-[1.5rem] border border-gray-100">
    <div class="flex-1">
      <label class="text-[10px] font-bold text-gray-400 uppercase block mb-1">Gender</label>
      <select name="gender" id="editGender" class="w-full bg-transparent border-none font-bold text-gray-800 text-sm focus:ring-0 outline-none cursor-pointer">
        <option value="male">Male</option>
        <option value="female">Female</option>
        <option value="unisex">Unisex</option>
      </select>
    </div>
    
    <div class="w-[1px] h-10 bg-gray-200"></div>

    <div class="flex-1 pl-2">
      <label class="text-[10px] font-bold text-gray-400 uppercase block mb-1">Status</label>
      <select name="status" id="editStatus" class="w-full bg-transparent border-none font-bold text-gray-800 text-sm focus:ring-0 outline-none cursor-pointer">
        <option value="active">Show Product</option>
        <option value="inactive">Hide Product</option>
      </select>
    </div>
  </div>

  <div class="form-group">
    <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-3 block text-blue-600">Current Gallery</label>
    <div id="editImagePreview" class="flex flex-wrap gap-3 p-3 bg-white rounded-2xl border-2 border-dashed border-gray-100 min-h-[80px] items-center">
      </div>
  </div>

  <div class="form-group">
    <label class="text-[10px] font-bold text-gray-400 uppercase ml-2 mb-1 block">Replace Photos</label>
    <input type="file" name="images" accept="image/*" multiple 
      class="w-full text-xs text-gray-400 file:mr-4 file:py-3 file:px-6 file:rounded-full file:border-0 file:text-[10px] file:font-black file:bg-gray-900 file:text-white cursor-pointer hover:file:bg-blue-600 transition-all" />
    <p class="text-[10px] text-gray-400 italic mt-2 ml-2">Keep empty to retain existing images</p>
  </div>

  <div class="modal-btns flex gap-4 pt-6">
    <button type="button" class="flex-1 py-4 text-[11px] font-black uppercase tracking-widest text-gray-400 hover:text-red-500 transition-colors" onclick="closeModal('editModal')">
      Cancel
    </button>
    <button type="submit" class="flex-[2] py-4 bg-gray-900 text-white rounded-2xl text-[11px] font-black uppercase tracking-widest shadow-xl shadow-gray-200 hover:bg-blue-600 hover:shadow-blue-200 transition-all active:scale-95">
      Update Changes
    </button>
  </div>
</div>
      </div>
    </div>
  </form>

  <script src="/js/watchesProduct.js"></script>
</body>

</html>