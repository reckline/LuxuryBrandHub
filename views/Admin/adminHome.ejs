      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">


            <a href="/admin-userlist" class="group bg-white p-8 rounded-3xl border border-slate-100 shadow-sm hover:shadow-xl hover:border-indigo-500 transition-all text-center">
                <div class="bg-indigo-50 text-indigo-600 w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
