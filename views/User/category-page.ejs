<%- include('../partials/userTop') %>
<%- include('../partials/userSidebar') %>
<%- include('../partials/userHeader') %>

<main class="w-full lg:pl-64 min-h-screen transition-all duration-300">
    <%- include('../partials/userBanner') %>
    
    <div class="flex justify-center items-center mb-4 pt-12">
        <div class="w-[95%] sm:w-4/5 md:w-3/5 lg:w-[95%] text-center relative group">
            <div class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 py-2 px-6 rounded-t-lg text-lg sm:text-xl font-bold tracking-wider uppercase text-white shadow-lg">
                <%= categoryName %> Brands
            </div>
            <div class="h-1 w-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-[length:200%_100%] animate-gradient-x"></div>
        </div>
    </div>

<% if (category && category.isGenderFilterEnabled === true) { %>
    <div class="flex justify-center mt-6 w-full px-6">
        <div class="w-full max-w-full">
            <select name="gender" id="gender" 
                class="w-full p-4 bg-white border-2 border-gray-200 rounded-2xl focus:border-purple-600 focus:ring-2 focus:ring-purple-200 outline-none transition-all cursor-pointer font-medium text-gray-700">
                <option value="all">ALL</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
                <option value="unisex">Unisex</option>
            </select>
        </div>
    </div>
<% } else { %>
    <% } %>

    <div id="product-container" class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 px-4 sm:px-6 py-8 sm:py-12">
        <% products.forEach(product => { %>
            <div class="group bg-white border border-gray-100 rounded-2xl sm:rounded-3xl p-3 sm:p-4 shadow-[0_4px_20px_rgb(0,0,0,0.05)] transition-all duration-300 hover:shadow-[0_20px_40px_rgb(0,0,0,0.1)] hover:-translate-y-1">
                <div class="relative overflow-hidden rounded-xl sm:rounded-2xl bg-gray-100 aspect-square">
                    <img src="<%= product.images[0] %>" class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105" alt="<%= product.title %>">
                    <div class="absolute top-3 left-3 bg-purple-900 text-white text-[9px] sm:text-[10px] font-bold px-2 sm:px-3 py-1 rounded-full uppercase tracking-widest">
                        <%= product.offerPercentage %>% Off
                    </div>
                </div>
                <div class="mt-4 sm:mt-5 px-1">
                    <h3 class="text-gray-900 font-semibold text-base sm:text-lg truncate"><%= product.title %></h3>
                    <div class="flex items-center justify-between mt-2 sm:mt-3">
                        <div>
                            <span class="text-gray-900 font-bold text-lg sm:text-xl">₹<%= product.offerPrice %></span>
                            <span class="text-gray-400 line-through text-xs sm:text-sm ml-1.5">₹<%= product.price %></span>
                        </div>
                    </div>
                    <a href="/view-product/<%= product._id %>" class="mt-4 sm:mt-6 w-full flex items-center justify-center bg-purple-900 hover:bg-black text-white py-2.5 sm:py-3 rounded-xl sm:rounded-2xl text-sm sm:text-base font-medium tracking-wide transition-all duration-300 active:scale-95">
                        SHOP NOW
                    </a>
                </div>
            </div>
        <% }) %>
    </div>
</main>

<a href="https://wa.me/917462844102" class="fixed bottom-6 right-6 z-50 bg-green-500 p-4 rounded-full text-white shadow-lg text-2xl hover:scale-110 transition">
    <i class="fab fa-whatsapp"></i>
</a>

<script>
    document.getElementById('gender').addEventListener('change', async function() {
        const selectedGender = this.value;
        const pathParts = window.location.pathname.split('/');
        const categoryId = pathParts[pathParts.length - 1]; 

        try {
            // Agar "all" select kiya hai, toh gender parameter bhejne ki zaroorat nahi
            const url = selectedGender === 'all' 
                ? `/products/filter?categoryId=${categoryId}` 
                : `/products/filter?gender=${selectedGender}&categoryId=${categoryId}`;

            const response = await fetch(url);
            const data = await response.json();
            
            if (data.success) {
                renderProducts(data.products);
            }
        } catch (err) {
            console.error("Filter Error:", err);
        }
    });

    function renderProducts(products) {
        const container = document.getElementById('product-container');
        container.innerHTML = '';
        
        if (!products || products.length === 0) {
            container.innerHTML = '<p class="text-center w-full py-10">No products found.</p>';
            return;
        }

        products.forEach(product => {
            container.innerHTML += `
            <div class="group bg-white border border-gray-100 rounded-2xl sm:rounded-3xl p-3 sm:p-4 shadow-[0_4px_20px_rgb(0,0,0,0.05)] transition-all duration-300 hover:shadow-[0_20px_40px_rgb(0,0,0,0.1)] hover:-translate-y-1">
                <div class="relative overflow-hidden rounded-xl sm:rounded-2xl bg-gray-100 aspect-square">
                    <img src="${product.images[0]}" class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105" alt="${product.title}">
                    <div class="absolute top-3 left-3 bg-purple-900 text-white text-[9px] sm:text-[10px] font-bold px-2 sm:px-3 py-1 rounded-full uppercase tracking-widest">
                        ${product.offerPercentage}% Off
                    </div>
                </div>
                <div class="mt-4 sm:mt-5 px-1">
                    <h3 class="text-gray-900 font-semibold text-base sm:text-lg truncate">${product.title}</h3>
                    <div class="flex items-center justify-between mt-2 sm:mt-3">
                        <div>
                            <span class="text-gray-900 font-bold text-lg sm:text-xl">₹${product.offerPrice}</span>
                            <span class="text-gray-400 line-through text-xs sm:text-sm ml-1.5">₹${product.price}</span>
                        </div>
                    </div>
                    <a href="/view-product/${product._id}" class="mt-4 sm:mt-6 w-full flex items-center justify-center bg-purple-900 hover:bg-black text-white py-2.5 sm:py-3 rounded-xl sm:rounded-2xl text-sm sm:text-base font-medium tracking-wide transition-all duration-300 active:scale-95">
                        SHOP NOW
                    </a>
                </div>
            </div>`;
        });
    }

    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('-translate-x-full');
    }
</script>
</body>
</html>