<%- include('../partials/userTop') %>
<%- include('../partials/userSidebar') %>
<%- include('../partials/userHeader') %>
<main class="flex-1 w-full lg:ml-64 transition-all duration-300">

    <%- include('../partials/userBanner') %>
    <%- include('../partials/secondHeader') %>

    <section class="px-4 py-16 max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-black text-center mb-12 tracking-tight 
           bg-gradient-to-r from-blue-600 via-purple-500 to-indigo-600 
           bg-clip-text text-transparent">
    SHOP BY CATEGORY
</h2>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
            <% categories.forEach((cat) => { %>
                <a href="/<%= cat.name ? cat.name.replace(/\s+/g, '').toLowerCase() : '#' %>" 
                   class="group relative bg-white p-4 rounded-[2rem] border border-gray-100 shadow-[0_10px_30px_rgba(0,0,0,0.03)] hover:shadow-[0_20px_50px_rgba(0,0,0,0.1)] transition-all duration-500 overflow-hidden">
                    <div class="overflow-hidden rounded-[1.5rem] mb-5 aspect-[4/3]">
                        <img src="<%= cat.imageUrl || '/images/placeholder.jpg' %>" 
                             class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" 
                             alt="<%= cat.name %>"
                             onerror="this.src='/images/placeholder.jpg'">
                    </div>
                    <h3 class="text-center font-extrabold text-lg text-gray-800 uppercase tracking-wide group-hover:text-blue-600 transition-colors">
                        <%= cat.name || 'Category' %>
                    </h3>
                </a>
            <% }) %>
        </div>

        <% categories.forEach(category => { %>
            <% if (category.brands && category.brands.length > 0) { %>
                <div class="mt-24">
                    <div class="flex items-center justify-between mb-12">
<h2 class="text-2xl md:text-4xl font-black uppercase tracking-tighter">
    <span class="bg-gradient-to-r from-gray-700 to-gray-900 bg-clip-text text-transparent">
        Luxury
    </span>
    <span class="bg-gradient-to-r from-blue-500 via-indigo-500 to-purple-600 bg-clip-text text-transparent ml-2">
        <%= category.name %>
    </span>
</h2>
                      <a href="/<%= category.name.replace(/\s+/g, '').toLowerCase() %>" 
   class="px-6 py-2 border-2 border-gray-900 text-gray-900 font-bold uppercase tracking-widest text-xs rounded-full hover:bg-gray-900 hover:text-white transition-all duration-300">
   View All
</a>
                    </div>
                    
                    <div class="grid grid-cols-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
                        <% category.brands.forEach(brand => { %>
                            <a href="/<%= brand.name.toLowerCase() %>" 
                               class="bg-white p-1 rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-blue-100 transition-all duration-300 hover:-translate-y-2 group flex flex-col items-center">
                                <div class="h-25 w-full flex items-center justify-center mb-4 p-2">
                                    <img src="<%= brand.image %>" 
                                         class="max-h-full w-auto object-contain transition-all duration-500" 
                                         alt="<%= brand.name %>">
                                </div>
                                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-gray-400 group-hover:text-gray-900 transition-colors">
                                    <%= brand.name %>
                                </p>
                            </a>
                        <% }) %>
                    </div>
                </div>
            <% } %>
        <% }) %>
    </section>

    <section class="bg-gray-900 py-24 px-4 overflow-hidden">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <div class="absolute -inset-4 bg-blue-600 rounded-3xl blur-xl opacity-20"></div>
                <img src="images/products/Shop.webp" class="relative w-full rounded-3xl shadow-2xl">
            </div>
            <div class="space-y-8 text-white">
                <h2 class="text-5xl font-black leading-tight">Elevate Your <br><span class="text-blue-500">Style Game</span></h2>
                <p class="text-gray-400 text-lg leading-relaxed">Luxury Brand Hub is your ultimate destination for high-quality footwear. We blend fashion with functionality to help you express your style.</p>
                <button class="bg-white text-gray-900 px-10 py-4 rounded-full font-bold hover:bg-blue-600 hover:text-white transition-all transform hover:scale-105">Shop Now</button>
            </div>
        </div>
    </section>

    <footer class="bg-white py-12 text-center border-t border-gray-100">
        <div class="flex justify-center space-x-8 mb-8">
            <a href="#" class="text-gray-400 hover:text-blue-600 transition-colors text-2xl"><i class="fab fa-facebook"></i></a>
            <a href="#" class="text-gray-400 hover:text-blue-600 transition-colors text-2xl"><i class="fab fa-instagram"></i></a>
        </div>
        <p class="text-gray-500 text-sm tracking-widest uppercase">© 2026 LuxuryBrandHub | All Rights Reserved</p>
    </footer>
</main>
<a href="https://wa.me/917462844102" class="fixed bottom-6 right-6 z-50 bg-green-500 p-4 rounded-full text-white shadow-lg text-2xl hover:scale-110 transition">
    <i class="fab fa-whatsapp"></i>
</a>

<script>
    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('-translate-x-full');
    }
</script>
</body>
</html>