<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rider Shoes</title>

  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/slider.css">
  <link rel="stylesheet" href="/css/userbody.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link rel="stylesheet" href="/css/whatsapp.css">
  <link rel="stylesheet" href="/css/productstyle.css" />
  <link rel="stylesheet" href="/css/heart.css">
  <link rel="stylesheet" href="/css/sopping.css">

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="/js/heart.js"></script>

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">


  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: {
              light: '#F3E8FF', /* Very light purple */
              DEFAULT: '#C084FC', /* Medium Purple */
              dark: '#6B21A8', /* Deep Purple for text */
              accent: '#A855F7'
            }
          }
        }
      }
    }
  </script>

</head>

<!-- ========================== Header ============================================-->



<body class="bg-gray-50 text-gray-800 font-sans antialiased">

  <%- include('../partials/userHeader') %>

  <div class="max-w-3xl mx-auto px-4 py-12 md:py-20">
    
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full mb-6 animate-bounce">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h1 class="text-4xl font-black tracking-tighter text-gray-900 uppercase">Order <span class="text-green-600">Confirmed!</span></h1>
      <p class="text-gray-500 font-medium mt-2">Thank you for shopping with us. Your style is on its way!</p>
      <div class="inline-block mt-4 px-4 py-1 bg-gray-900 text-white text-[10px] font-bold rounded-full uppercase tracking-widest">
        ID: #<%= order._id %>
      </div>
    </div>

    <div class="space-y-4 mb-10">
      <h3 class="text-xs font-black text-gray-400 uppercase tracking-[0.2em] ml-2">Order Items</h3>
      
      <% order.items.forEach(item => { %>
        <div class="flex items-center gap-5 bg-white p-4 rounded-[2rem] shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="w-24 h-24 flex-shrink-0 bg-gray-50 rounded-2xl overflow-hidden border border-gray-50">
            <img src="<%= item.product.images[0] %>" alt="product" class="w-full h-full object-cover">
          </div>

          <div class="flex-grow">
            <h2 class="text-sm font-black text-gray-900 leading-tight mb-1 uppercase tracking-tight">
              <%= item.product.title %>
            </h2>
            <div class="flex flex-wrap gap-3">
              <span class="text-[10px] font-bold text-gray-400 uppercase bg-gray-50 px-2 py-1 rounded-md">Qty: <%= item.qty %></span>
              <% if(item.size) { %>
                <span class="text-[10px] font-bold text-blue-600 uppercase bg-blue-50 px-2 py-1 rounded-md">Size: <%= item.size %></span>
              <% } %>
            </div>
            <p class="text-xs font-bold text-gray-900 mt-2 italic">₹<%= item.price %> per unit</p>
          </div>

          <div class="text-right pr-2">
            <p class="text-sm font-black text-gray-900 italic">₹<%= item.total %></p>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="bg-gray-900 rounded-[2.5rem] p-8 text-white shadow-2xl shadow-blue-100 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-32 h-32 bg-blue-500 opacity-10 rounded-full -mr-16 -mt-16"></div>
      
      <div class="flex justify-between items-end border-b border-gray-700 pb-6 mb-6">
        <div>
          <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Grand Total</p>
          <p class="text-4xl font-black italic">₹<%= order.totalAmount %></p>
        </div>
        <div class="text-right">
          <span class="px-3 py-1 bg-green-500 text-[9px] font-black uppercase rounded-full">
            <%= order.orderStatus %>
          </span>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Payment Method</p>
          <p class="text-xs font-bold uppercase"><%= order.paymentMethod %></p>
        </div>
        <div class="text-right">
          <p class="text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1">Payment Status</p>
          <p class="text-xs font-bold uppercase text-blue-400"><%= order.paymentStatus %></p>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center flex flex-col md:flex-row gap-4 justify-center">
      <a href="/" class="px-10 py-4 bg-white border-2 border-gray-900 text-gray-900 rounded-full text-xs font-black uppercase tracking-widest hover:bg-gray-900 hover:text-white transition-all transform hover:-translate-y-1 active:scale-95">
        Continue Shopping
      </a>
      <!-- <a href="/user/orders" class="px-10 py-4 bg-blue-600 text-white rounded-full text-xs font-black uppercase tracking-widest shadow-xl shadow-blue-200 hover:bg-blue-700 transition-all transform hover:-translate-y-1 active:scale-95">
        Track Your Order
      </a> -->
    </div>

  </div>

</body>
</html>
