<aside class="sidebar" id="sidebar" style="overflow: overlay;">

      <nav>
    <a href="/admin/admin-home" class="nav-link"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
    <a href="/admin/admin-userlist" class="nav-link"><i class="fa-solid fa-users"></i> My Users</a>
    <a href="/admin/admin-category" class="nav-link"><i class="fa-solid fa-folder-plus"></i> Manage Categories</a>

    <div class="mt-4 border-t pt-4">
        <p class="text-xs text-gray-500 uppercase px-4 mb-2">My Categories</p>
        <% if (locals.allCategories && allCategories.length > 0) { %>
            <% allCategories.forEach(cat => { %>
                <a href="/admin/category/<%= cat.name.toLowerCase() %>" class="nav-link">
                    <i class="fa-solid fa-tag"></i> <%= cat.name %>
                </a>
            <% }) %>
        <% } %>
    </div>

    <div class="mt-4 border-t pt-4">
        <a href="/admin/admin-newoder" class="nav-link"><i class="fa-solid fa-cart-shopping"></i> New Orders</a>
        <a href="/admin/admin-order-history" class="nav-link"><i class="fa-solid fa-cart-shopping"></i> Orders History</a>
        <a href="/logout" class="nav-link"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
    </div>
</nav>
  </aside>




