<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Categories | Admin Panel</title>
     <link rel="stylesheet" href="/css/adminDashbord.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com"></script>
    
</head>
<body class="bg-gray-100 font-sans">
<header class="sticky top-0 z-50 bg-gradient-to-r from-purple-700 to-indigo-800 shadow-lg px-6 py-4 flex items-center justify-between transition-all duration-300">
    
    <div class="flex items-center gap-4">
        <div class="relative">
            <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white font-bold text-xl border-2 border-white/30 shadow-inner">
                <%= admin.username.charAt(0).toUpperCase() %>
            </div>
            <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-400 border-2 border-indigo-800 rounded-full"></span>
        </div>
        
        <div>
            <p class="text-[10px] text-purple-200 uppercase tracking-widest font-bold">Administrator</p>
            <h1 class="text-white font-bold text-lg tracking-tight"><%- admin.username %></h1>
        </div>
    </div>

<button 
    onclick="toggleSidebar()" 
    class="lg:hidden group p-3 rounded-xl bg-white/10 hover:bg-white text-white hover:text-indigo-900 backdrop-blur-sm transition-all duration-300 border border-white/20 hover:border-white shadow-xl focus:outline-none"
    aria-label="Toggle Sidebar"
>
    <i class="fa-solid fa-bars text-xl group-hover:scale-110 transition-transform"></i>
</button>
</header>



